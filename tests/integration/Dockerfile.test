# EthPillar Integration Test Environment - with systemd
#
# Uses ubuntu:24.04 with systemd enabled as PID 1.
# This allows integration tests to truly validate that generated service files
# are syntactically correct, load cleanly (daemon-reload), and can be started
# and stopped via systemctl - the same lifecycle used in production.
#
# Required docker run flags (handled by run_docker_tests.ps1):
#   --privileged
#   --tmpfs /run
#   --tmpfs /run/lock
#   -v /sys/fs/cgroup:/sys/fs/cgroup:rw
#   --cgroupns=host
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Container infrastructure only. Runtime tools (curl, jq, wget, chrony, …) are
# installed by deploy setup_node() so tests verify EthPillar pulls its own deps.
RUN apt-get update && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
    ca-certificates \
    systemd systemd-sysv \
    sudo \
    python3 \
    bats \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Remove units that are problematic inside containers
RUN find /lib/systemd/system/sysinit.target.wants/ -name "*.service" ! -name "systemd-tmpfiles-setup.service" -delete \
    && rm -f /lib/systemd/system/multi-user.target.wants/* \
    && rm -f /etc/systemd/system/*.wants/* \
    && rm -f /lib/systemd/system/local-fs.target.wants/* \
    && rm -f /lib/systemd/system/sockets.target.wants/*udev* \
    && rm -f /lib/systemd/system/sockets.target.wants/*initctl* \
    && rm -f /lib/systemd/system/basic.target.wants/* \
    && rm -f /lib/systemd/system/anaconda.target.wants/*

ENV TERM=xterm

WORKDIR /ethpillar

# Cache wrappers (separate files — heredocs require BuildKit and break plain `docker build` on CI).
COPY tests/integration/docker/wget-wrapper.sh /usr/local/sbin/wget
COPY tests/integration/docker/tar-wrapper.sh /usr/local/sbin/tar
COPY tests/integration/docker/unzip-wrapper.sh /usr/local/sbin/unzip
RUN chmod +x /usr/local/sbin/wget /usr/local/sbin/tar /usr/local/sbin/unzip

# Use systemd as PID 1. Integration tests run via 'docker exec' after container starts.
CMD ["/lib/systemd/systemd"]
